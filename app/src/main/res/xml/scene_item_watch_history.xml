<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <Transition
        app:constraintSetStart="@id/start"
        app:constraintSetEnd="@id/end"
        app:duration="300"
        app:transitionDisable="false">

        <OnSwipe
            app:touchRegionId="@id/cardView"
            app:touchAnchorSide="end"
            app:dragDirection="dragStart"
            app:maxVelocity="4.2"
            app:dragScale="1.5"
            app:moveWhenScrollAtTop="true"
            app:onTouchUp="autoComplete" />

        <KeyFrameSet>
            <KeyAttribute
                app:motionTarget="@id/deleteBackground"
                app:framePosition="0"
                android:translationX="0dp"
                android:alpha="0" />

            <KeyAttribute
                app:motionTarget="@id/deleteBackground"
                app:framePosition="30"
                android:translationX="0dp"
                android:alpha="1" />

            <KeyAttribute
                app:motionTarget="@id/deleteBackground"
                app:framePosition="100"
                android:translationX="-1000dp"
                android:alpha="1" />

            <KeyAttribute
                app:motionTarget="@id/cardView"
                app:framePosition="0"
                android:translationX="0dp"
                android:alpha="1" />

            <KeyAttribute
                app:motionTarget="@id/cardView"
                app:framePosition="30"
                android:translationX="-120dp"
                android:alpha="0.8" />

            <KeyAttribute
                app:motionTarget="@id/cardView"
                app:framePosition="100"
                android:translationX="-1000dp"
                android:alpha="0.3" />
        </KeyFrameSet>
    </Transition>

    <Transition
        app:constraintSetStart="@id/end"
        app:constraintSetEnd="@id/start"
        app:duration="250">

        <KeyFrameSet>
            <KeyAttribute
                app:motionTarget="@id/deleteBackground"
                app:framePosition="0"
                android:translationX="-1000dp"
                android:alpha="1" />

            <KeyAttribute
                app:motionTarget="@id/deleteBackground"
                app:framePosition="70"
                android:translationX="0dp"
                android:alpha="0.5" />

            <KeyAttribute
                app:motionTarget="@id/deleteBackground"
                app:framePosition="100"
                android:translationX="0dp"
                android:alpha="0" />

            <KeyAttribute
                app:motionTarget="@id/cardView"
                app:framePosition="0"
                android:translationX="-1000dp"
                android:alpha="0.3" />

            <KeyAttribute
                app:motionTarget="@id/cardView"
                app:framePosition="100"
                android:translationX="0dp"
                android:alpha="1" />
        </KeyFrameSet>
    </Transition>

    <ConstraintSet android:id="@+id/start">
        <Constraint android:id="@id/cardView">
            <Layout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <Transform
                android:translationX="0dp"
                android:alpha="1" />
        </Constraint>

        <Constraint android:id="@id/deleteBackground">
            <Layout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="@+id/cardView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/cardView" />
            <Transform
                android:translationX="0dp"
                android:alpha="0" />
            <PropertySet android:visibility="gone" />
        </Constraint>
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">
        <Constraint android:id="@id/cardView">
            <Layout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <Transform
                android:translationX="-1000dp"
                android:alpha="0.3" />
        </Constraint>

        <Constraint android:id="@id/deleteBackground">
            <Layout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="20dp"
                app:layout_constraintBottom_toBottomOf="@+id/cardView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/cardView" />
            <Transform
                android:translationX="-1000dp"
                android:alpha="1"
                android:scaleX="1.0"
                android:scaleY="1.0" />
            <PropertySet android:visibility="visible" />
        </Constraint>
    </ConstraintSet>

</MotionScene>