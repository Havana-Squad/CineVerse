<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_tertiary" />
            <corners android:radius="@dimen/radius_lg"/>
            <stroke android:width="1dp" android:color="@color/brand_secondary" />
        </shape>
    </item>

    <item android:state_selected="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/background_card" />
            <corners android:radius="@dimen/radius_lg"/>
            <stroke android:width="1dp" android:color="@android:color/transparent" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_card" />
            <corners android:radius="@dimen/radius_lg"/>
            <stroke android:width="1dp" android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>