<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.myList.MyListsViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.myList.MyListsFragment"
        android:background="@color/background_screen">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/back_button"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/arrow_left_back_icon"
                android:layout_marginStart="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                style="@style/Title.SM"
                android:textColor="@color/shade_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_collections"
                android:layout_marginStart="48dp"
                app:layout_constraintTop_toTopOf="@id/back_button"
                app:layout_constraintBottom_toBottomOf="@id/back_button"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/saved_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:overScrollMode="never"
            android:paddingTop="@dimen/spacing_small"
            android:layout_marginBottom="12dp"
            android:paddingBottom="80dp"
            app:items="@{viewModel.createdListUIState.createdList}"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_marginTop="56dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header"
            tools:listitem="@layout/item_saved_list" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/floating_action_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/RoundFAB"
            android:layout_margin="16dp"
            android:onClick="@{()->viewModel.onCreateList()}"
            app:backgroundTint="@color/brand_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/ic_baseline_add_24"
            app:tint="@color/white_primary" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/need_login_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/need_login_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:backgroundTint="@color/brand_tertiary">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/login_icon"
                    android:layout_gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/need_login_header"
                style="@style/Title.SM"
                android:textColor="@color/shade_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/need_login_header"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/need_login_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                style="@style/Body_SM.Medium"
                android:textColor="@color/shade_secondary"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:text="@string/need_login_content"
                app:layout_constraintTop_toBottomOf="@id/need_login_header"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.Group
            android:id="@+id/succces_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="
                    saved_list,
                    floating_action_button"
            app:error="@{viewModel.createdListUIState.error}"
            app:loading="@{viewModel.createdListUIState.loading}" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/needLoginGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="need_login_view"
            app:showWhenNoLogin="@{viewModel.createdListUIState.error}" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/loading"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:isVisible="@{viewModel.createdListUIState.loading}"
            app:trackColor="@color/brand_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/no_connection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/no_connection_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:backgroundTint="@color/secondary_red">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/station_icon"
                    android:layout_gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/no_connection_header"
                style="@style/Title.SM"
                android:textColor="@color/shade_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oops! No Internet"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/no_connection_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                style="@style/Body_SM.Medium"
                android:textColor="@color/shade_secondary"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:text="Looks like you're offline. Let's reconnect so you don't miss out!"
                app:layout_constraintTop_toBottomOf="@id/no_connection_header"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/no_connection_btn"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/button_primary"
            android:textColor="@color/button_onPrimary"
            android:text="Try Again"
            app:cornerRadius="@dimen/radius_md"
            android:onClick="@{() -> viewModel.getData()}"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/no_connection"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.constraintlayout.widget.Group
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="no_connection,no_connection_btn"
            app:showWhenNoInternet="@{viewModel.createdListUIState.error}" />

        <!--        empty List          -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/no_collection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/no_collection_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:backgroundTint="@color/brand_tertiary">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/video_library_icon"
                    android:layout_gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/no_collection_header"
                style="@style/Title.SM"
                android:textColor="@color/shade_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_collections_header"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/no_collection_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                style="@style/Body_SM.Medium"
                android:textColor="@color/shade_secondary"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:text="@string/no_collection_content_text"
                app:layout_constraintTop_toBottomOf="@id/no_collection_header"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/no_collection_btn"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/button_primary"
            android:textColor="@color/button_onPrimary"
            android:text="@string/start_collecting"
            app:cornerRadius="@dimen/radius_md"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/no_collection"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.constraintlayout.widget.Group
            android:id="@+id/empty_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="no_collection,no_collection_btn"
            app:isListEmpty="@{viewModel.createdListUIState.isEmpty}" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>