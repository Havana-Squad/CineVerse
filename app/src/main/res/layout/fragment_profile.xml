<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.profile.ProfileViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_screen"
        android:padding="@dimen/text_title_sm">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text_my_profile"
            style="@style/Title.SM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/chip_height"
            android:text="@string/my_profile"
            android:textColor="@color/shade_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <androidx.cardview.widget.CardView
            android:id="@+id/card_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="@dimen/radius_large"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_my_profile">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/image_user"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:scaleType="centerInside"
                    android:background="@drawable/gray_background"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:posterImage="@{ viewModel.profileDetailsUIState.avatarPath }"
                    tools:src="@drawable/profile" />


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_name_profile"
                    style="@style/Body_LG.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="8dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingTop="4dp"
                    android:scrollHorizontally="true"
                    android:text="@{viewModel.profileDetailsUIState.isLoggedIn  ? viewModel.profileDetailsUIState.name : @string/login_or_signup}"
                    android:textColor="@color/shade_primary"
                    app:layout_constraintStart_toEndOf="@id/image_user"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Captain America" />


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_user_name_profile"
                    style="@style/Body_SM.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingTop="4dp"
                    android:scrollHorizontally="true"
                    android:text="@{viewModel.profileDetailsUIState.isLoggedIn  ? viewModel.profileDetailsUIState.username : @string/personalize_experience}"
                    android:textColor="@color/shade_secondary"
                    app:layout_constraintStart_toEndOf="@id/image_user"
                    app:layout_constraintTop_toBottomOf="@id/text_name_profile"
                    tools:text="captain_America" />

                <ImageView
                    android:id="@+id/profile_selector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_right"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/shade_tertiary" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_history"
            style="@style/ProfileButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:onClick="@{() -> viewModel.onClickWatchHistory()}"
            android:text="@string/history"
            app:icon="@drawable/ic_history"
            app:layout_constraintEnd_toStartOf="@id/btn_collections"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_profile" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_collections"
            style="@style/ProfileButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:onClick="@{()->viewModel.onClickMyCollection()}"
            android:text="@string/my_collections"
            app:icon="@drawable/ic_video_library"
            app:layout_constraintEnd_toStartOf="@id/btn_ratings"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/btn_history"
            app:layout_constraintTop_toTopOf="@+id/btn_history" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ratings"
            style="@style/ProfileButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:onClick="@{() -> viewModel.onClickRatedMovies()}"
            android:text="@string/my_ratings_"
            app:icon="@drawable/ic_star"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/btn_collections"
            app:layout_constraintTop_toTopOf="@+id/btn_history" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text_settings"
            style="@style/Title.SM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings"
            android:textColor="@color/shade_primary"
            app:layout_constraintBottom_toTopOf="@id/card_settings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_history" />


        <androidx.cardview.widget.CardView
            android:id="@+id/card_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_settings">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/image_moon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/ic_moon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/brand_primary" />


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_theme"
                    style="@style/Body_MD.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/dark_mode"
                    android:textColor="@color/shade_primary"
                    app:layout_constraintBottom_toBottomOf="@+id/image_moon"
                    app:layout_constraintStart_toEndOf="@id/image_moon"
                    app:layout_constraintTop_toTopOf="@id/image_moon" />


                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_theme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:longClickable="false"
                    android:soundEffectsEnabled="false"
                    android:thumb="@drawable/switch_thumb"
                    app:layout_constraintBottom_toBottomOf="@id/image_moon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/image_moon"
                    app:track="@drawable/switch_track" />

                <View
                    android:id="@+id/horizontal_line1"

                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="18dp"
                    android:background="@color/shade_quaternary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_moon" />

                <ImageView
                    android:id="@+id/image_language"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:src="@drawable/ic_language"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_moon"
                    app:tint="@color/brand_primary" />


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_language"
                    style="@style/Body_MD.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/language"
                    android:textColor="@color/shade_primary"
                    app:layout_constraintBottom_toBottomOf="@+id/image_language"
                    app:layout_constraintStart_toEndOf="@id/image_language"
                    app:layout_constraintTop_toTopOf="@id/image_language" />


                <ImageView
                    android:id="@+id/language_selector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_right"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/image_language"
                    app:tint="@color/shade_tertiary" />


                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="18dp"
                    android:background="@color/shade_quaternary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_language" />

                <ImageView
                    android:id="@+id/image_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:src="@drawable/ic_color_swatch"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_language"
                    app:tint="@color/brand_primary" />


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_content"
                    style="@style/Body_MD.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/content_preferences"
                    android:textColor="@color/shade_primary"
                    app:layout_constraintBottom_toBottomOf="@+id/image_content"
                    app:layout_constraintStart_toEndOf="@id/image_content"
                    app:layout_constraintTop_toTopOf="@id/image_content" />


                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_right"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/image_content"
                    app:tint="@color/shade_tertiary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="18dp"
                    android:background="@color/shade_quaternary"
                    android:visibility="@{viewModel.profileDetailsUIState.isLoggedIn? View.VISIBLE : View.GONE}"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_content" />

                <ImageView
                    android:id="@+id/image_logout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:src="@drawable/ic_logout"
                    android:visibility="@{viewModel.profileDetailsUIState.isLoggedIn? View.VISIBLE : View.GONE}"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_content"
                    app:tint="@color/primary_red" />


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/text_logout"
                    style="@style/Body_MD.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/logout"
                    android:textColor="@color/primary_red"
                    android:visibility="@{viewModel.profileDetailsUIState.isLoggedIn? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="@+id/image_logout"
                    app:layout_constraintStart_toEndOf="@id/image_logout"
                    app:layout_constraintTop_toTopOf="@id/image_logout" />


                <ImageView
                    android:id="@+id/logout_selector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_arrow_right"
                    android:visibility="@{viewModel.profileDetailsUIState.isLoggedIn? View.VISIBLE : View.GONE}"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/image_logout"
                    app:tint="@color/primary_red" />


            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>


        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/text_version"
            style="@style/Body_SM.Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/version_1_0_1"
            android:textColor="@color/shade_tertiary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_settings" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>