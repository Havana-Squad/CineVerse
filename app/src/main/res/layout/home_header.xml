<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="userName"
            type="String" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_color"
        android:paddingStart="@dimen/spacing_medium"
        android:paddingVertical="9dp"
        tools:ignore="RtlSymmetry">

        <ImageView
            android:id="@+id/image_logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/cineverse_logo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_welcome"
            style="@style/Body_SM.Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            android:text="@string/welcome"
            android:textColor="@color/shade_secondary"
            app:layout_constraintBottom_toTopOf="@id/text_username"
            app:layout_constraintStart_toEndOf="@id/image_logo"
            app:layout_constraintTop_toTopOf="@id/image_logo"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/text_username"
            style="@style/Title.SM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{userName}"
            android:textColor="@color/shade_primary"
            app:layout_constraintBottom_toBottomOf="@id/image_logo"
            app:layout_constraintStart_toStartOf="@id/text_welcome"
            app:layout_constraintTop_toBottomOf="@id/text_welcome"
            tools:text="Mustafa Ahmed" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
